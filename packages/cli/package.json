{
  "name": "fairstack",
  "version": "0.1.0",
  "description": "FairStack CLI — generate images, video, voice, and music from your terminal",
  "types": "./dist/index.d.ts",
  "bin": {
    "fairstack": "dist/index.js"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "format:check": "biome format src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "ai",
    "image-generation",
    "video-generation",
    "voice",
    "tts",
    "music",
    "fairstack",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FairStackAI/cli.git",
    "directory": "packages/cli"
  },
  "homepage": "https://fairstack.ai",
  "author": "FairStack <support@fairstack.ai>",
  "bugs": {
    "url": "https://github.com/FairStackAI/cli/issues"
  },
  "license": "MIT",
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@types/node": "^22.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.4"
  }
}
